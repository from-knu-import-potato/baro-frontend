{
  // 기본 포맷터를 Prettier로 설정
  "editor.defaultFormatter": "esbenp.prettier-vscode",

  // 파일 저장 시 자동으로 포맷팅(정렬) 실행
  "editor.formatOnSave": true,

  // 저장 시 ESLint가 고칠 수 있는 에러들을 자동으로 수정
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit"
  },

  // 언어별 세부 설정 (TypeScript/React)
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },

  // 에디터 가이드라인 (코드가 너무 길어지지 않게 줄 세우기)
  "editor.rulers": [100],
  "editor.tabSize": 2,

  // 파일 끝에 빈 줄 자동 추가 (깃허브 컨벤션)
  "files.insertFinalNewline": true,

  // 검색 및 탐색에서 제외할 폴더
  "search.exclude": {
    "**/node_modules": true,
    "**/dist": true,
    "**/.husky": true
  }
}
